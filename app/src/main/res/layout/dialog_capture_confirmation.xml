<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/cardBackground"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="INSPECTION SAVED"
        android:textColor="@color/statusHealthy"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Panel:"
            android:textColor="@color/colorLightGray"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/savedPanelIdLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PNL-A7-4402"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Issue:"
            android:textColor="@color/colorLightGray"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/savedIssueLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hotspot"
            android:textColor="@color/statusCritical"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="ΔT:"
            android:textColor="@color/colorLightGray"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/savedDeltaTempLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+18.5°C"
            android:textColor="@color/statusCritical"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="GPS:"
            android:textColor="@color/colorLightGray"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/savedGpsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="36.1, -115.2"
            android:textColor="@color/white"
            android:textSize="14sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/buttonNextPanel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="72dp"
            android:text="NEXT PANEL"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/black"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/buttonOpenMapFromConfirm"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="72dp"
            android:text="OPEN MAP"
            android:textSize="16sp"
            android:backgroundTint="@color/white"
            android:textColor="@color/black"/>
    </LinearLayout>

</LinearLayout>
