<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Breadcrumb Navigation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/settingsBackButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt; Back"
                android:textColor="#00D9FF"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Home > SolarSnap > Settings"
                android:textColor="#C3C3C3"
                android:textSize="12sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/settingsHelpIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="?"
                android:textColor="#00D9FF"
                android:textSize="18sp"
                android:layout_marginEnd="16dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/settingsResetIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↻"
                android:textColor="#00D9FF"
                android:textSize="18sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- User Profile Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2B3D"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USER PROFILE"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/settingsUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inspector: Inspector_12"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/settingsUserRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Role: Field Engineer"
                android:textColor="#C3C3C3"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/settingsUserCompany"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Company: SolarTech Ltd"
                android:textColor="#C3C3C3"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <Button
                    android:id="@+id/buttonSwitchUser"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Switch User"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:background="#FFFFFF"
                    android:layout_marginEnd="12dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/buttonLogout"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Logout"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:background="#F44336"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>
        </LinearLayout>

        <!-- Thermal Detection Settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2B3D"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THERMAL DETECTION"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thermal Anomaly Thresholds"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Warning Level:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/warningThresholdValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ΔT ≥ 8°C"
                    android:textColor="#FF9800"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/warningThresholdSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="20"
                android:progress="8"
                android:progressTint="#FF9800"
                android:thumbTint="#FF9800"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Critical Level:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/criticalThresholdValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ΔT ≥ 15°C"
                    android:textColor="#F44336"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/criticalThresholdSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="30"
                android:progress="15"
                android:progressTint="#F44336"
                android:thumbTint="#F44336"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2A3F54"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detection Features"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hotspot Detection"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchHotspotDetection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cell Crack Detection"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchCellCrackDetection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Diode Fault Detection"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchDiodeFaultDetection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Camera Configuration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2B3D"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CAMERA CONFIGURATION"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Thermal Resolution:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/thermalResolutionValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="640x480"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Frame Rate:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/frameRateValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30 FPS"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Temperature Range:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tempRangeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-20°C to 120°C"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thermal Palette"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/buttonPaletteIron"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Iron"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:background="#FFFFFF"
                    android:layout_marginEnd="6dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/buttonPaletteRainbow"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Rainbow"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:background="#2A3F54"
                    android:layout_marginEnd="6dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/buttonPaletteGrayscale"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Grayscale"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:background="#2A3F54"
                    android:layout_marginEnd="6dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/buttonPaletteArctic"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Arctic"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:background="#2A3F54"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Emissivity:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/emissivityValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.95"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/buttonCalibrate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="CALIBRATE CAMERA"
                android:textColor="#000000"
                android:textSize="14sp"
                android:background="#00D9FF" />
        </LinearLayout>

        <!-- Inspection Preferences -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2B3D"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INSPECTION PREFERENCES"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Auto-save Inspections"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoSave"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Require Panel ID Scan"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchRequirePanelScan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Default Inspection Mode"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <RadioGroup
                android:id="@+id/radioGroupInspectionMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioFullInspection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Full Inspection (Quick Scan removed)"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:checked="true"
                    android:layout_marginBottom="8dp" />
            </RadioGroup>
        </LinearLayout>

        <!-- Connectivity and Cloud Settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2B3D"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECTIVITY &amp; CLOUD"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Network Status:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/networkStatusValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LTE Connected"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cloud Sync"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchCloudSync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Auto-upload"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoUpload"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <Button
                    android:id="@+id/buttonTestConnection"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Test Connection"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:background="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/buttonManualSync"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Manual Sync"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:background="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/buttonCloudLogin"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Cloud Login"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:background="#FFFFFF"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>
        </LinearLayout>

        <!-- Storage Management -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2B3D"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STORAGE MANAGEMENT"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Storage Usage"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Inspection Data:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/inspectionDataSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.3 GB"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Thermal Images:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/thermalImagesSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.1 GB"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Available Space:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/availableSpace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12 GB (72%)"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/storageProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progress="28"
                android:progressTint="#FF9800"
                android:progressBackgroundTint="#2A3F54"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <Button
                    android:id="@+id/buttonClearUploaded"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Clear Uploaded"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:background="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/buttonDeleteOld"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Delete Old"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:background="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/buttonCompressImages"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Compress"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:background="#FFFFFF"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>
        </LinearLayout>

        <!-- System Information -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2B3D"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEM INFORMATION"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Device:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/deviceNameValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FLIR ACE IX"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="App Version:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/appVersionValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.2.0"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Thermal Firmware:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/firmwareVersionValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3.4.1"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Battery Health:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/batteryHealthValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <Button
                    android:id="@+id/buttonCheckUpdates"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Check Updates"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:background="#00D9FF"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/buttonResetApp"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Reset App"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="#F44336"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/buttonDiagnostics"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Diagnostics"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:background="#FFFFFF"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
