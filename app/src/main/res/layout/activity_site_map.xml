<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black">

    <!-- 1. BREADCRUMB NAVIGATION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorPrimary"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Home > SolarSnap > Map"
            android:textColor="@color/white"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/mapGpsIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📡"
            android:textColor="@color/statusHealthy"
            android:textSize="16sp"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"/>

        <TextView
            android:id="@+id/mapSyncIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☁"
            android:textColor="@color/statusHealthy"
            android:textSize="16sp"
            android:paddingEnd="8dp"/>

        <TextView
            android:id="@+id/mapBatteryIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔋"
            android:textColor="@color/statusHealthy"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- 2. SITE OVERVIEW BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/cardBackground"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="SITE:"
                android:textColor="@color/colorAccent"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/mapSiteNameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NV Solar Farm 04"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Panels: 1200"
                android:textColor="@color/white"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/mapInspectedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inspected: 640"
                android:textColor="@color/statusHealthy"
                android:textSize="13sp"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:id="@+id/mapRemainingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remaining: 560"
                android:textColor="@color/colorLightGray"
                android:textSize="13sp"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/mapProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:progress="53"
            android:progressTint="@color/colorAccent"
            android:progressBackgroundTint="@color/colorPrimary"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonMapChangeSite"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="Change Site"
                android:textSize="13sp"
                android:backgroundTint="@color/white"
                android:textColor="@color/black"
                android:layout_marginEnd="12dp"/>

            <Button
                android:id="@+id/buttonFilterFaults"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="Filter Faults"
                android:textSize="13sp"
                android:backgroundTint="@color/white"
                android:textColor="@color/black"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 3. SOLAR FARM MAP (Main Area - 70%) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="7"
        android:background="@color/black">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/mapGridContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Map grid will be dynamically generated here -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SOLAR FARM MAP"
                        android:textColor="@color/colorAccent"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"/>

                </LinearLayout>
            </HorizontalScrollView>
        </ScrollView>

        <!-- 4. PANEL DETAILS POPUP (Initially Hidden) -->
        <LinearLayout
            android:id="@+id/panelDetailsPopup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/cardBackground"
            android:layout_gravity="bottom"
            android:layout_margin="16dp"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECTED PANEL"
                android:textColor="@color/colorAccent"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Panel ID:"
                    android:textColor="@color/colorLightGray"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/popupPanelIdLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PNL-A7-4402"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Row:"
                    android:textColor="@color/colorLightGray"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/popupRowLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="String:"
                    android:textColor="@color/colorLightGray"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/popupStringLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Status:"
                    android:textColor="@color/colorLightGray"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/popupStatusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CRITICAL"
                    android:textColor="@color/statusCritical"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="ΔT:"
                    android:textColor="@color/colorLightGray"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/popupDeltaTempLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+18.5°C"
                    android:textColor="@color/statusCritical"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/popupLastInspectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last inspection: 14:02"
                android:textColor="@color/colorLightGray"
                android:textSize="12sp"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/buttonViewImage"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:text="View Image"
                    android:textSize="14sp"
                    android:backgroundTint="@color/colorAccent"
                    android:textColor="@color/black"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/buttonNavigateToPanel"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:text="Navigate"
                    android:textSize="14sp"
                    android:backgroundTint="@color/white"
                    android:textColor="@color/black"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/buttonReinspect"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:text="Reinspect"
                    android:textSize="14sp"
                    android:backgroundTint="@color/white"
                    android:textColor="@color/black"/>
            </LinearLayout>

            <Button
                android:id="@+id/buttonClosePopup"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Close"
                android:textSize="13sp"
                android:backgroundTint="@color/colorLightGray"
                android:textColor="@color/black"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- 5. NAVIGATION CONTROLS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/black"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/buttonZoomIn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:text="Zoom +"
                android:textSize="14sp"
                android:backgroundTint="@color/white"
                android:textColor="@color/black"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/buttonZoomOut"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:text="Zoom -"
                android:textSize="14sp"
                android:backgroundTint="@color/white"
                android:textColor="@color/black"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/buttonCenterGPS"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:text="Center"
                android:textSize="14sp"
                android:backgroundTint="@color/white"
                android:textColor="@color/black"/>
        </LinearLayout>

        <Button
            android:id="@+id/buttonNextPanel"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="NEXT UNSCANNED PANEL\nRow 12 Panel 9"
            android:textSize="14sp"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/black"/>
    </LinearLayout>

</LinearLayout>
