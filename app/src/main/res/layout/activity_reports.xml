<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Breadcrumb Navigation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/backButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt; Back"
                android:textColor="#00D9FF"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Home > SolarSnap > Reports"
                android:textColor="#C3C3C3"
                android:textSize="12sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/filterIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙"
                android:textColor="#00D9FF"
                android:textSize="18sp"
                android:layout_marginEnd="16dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/exportIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📤"
                android:textColor="#00D9FF"
                android:textSize="18sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Report Selection Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2B3D"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPORT SELECTION"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/reportSiteLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Site: NV Solar Farm 04"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/reportDateLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date Range: Today"
                android:textColor="#C3C3C3"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/reportInspectorLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inspector: All"
                android:textColor="#C3C3C3"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <!-- Filter Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <Button
                    android:id="@+id/filterToday"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Today"
                    android:textColor="#000000"
                    android:background="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/filterLast7Days"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Last 7 Days"
                    android:textColor="#FFFFFF"
                    android:background="#2A3F54"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/filterLast30Days"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Last 30 Days"
                    android:textColor="#FFFFFF"
                    android:background="#2A3F54"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/filterCustom"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Custom"
                    android:textColor="#FFFFFF"
                    android:background="#2A3F54"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>
        </LinearLayout>

        <!-- Inspection Summary -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2B3D"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INSPECTION SUMMARY"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Panels inspected:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/summaryInspectedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="640"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Remaining:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/summaryRemainingCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="560"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Coverage:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/summaryCoveragePercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="53%"
                    android:textColor="#4CAF50"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/summaryProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progress="53"
                android:progressTint="#4CAF50"
                android:progressBackgroundTint="#2A3F54"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/summaryAvgTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Average panel temperature: 41.2°C"
                android:textColor="#C3C3C3"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/summaryMaxAnomaly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maximum anomaly detected: +18.5°C"
                android:textColor="#F44336"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Fault Analytics -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2B3D"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FAULT DISTRIBUTION"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Critical faults:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/faultCriticalCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4"
                    android:textColor="#F44336"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/faultCriticalDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●●●●"
                android:textColor="#F44336"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Warnings:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/faultWarningCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="11"
                    android:textColor="#FF9800"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/faultWarningDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●●●●●●●●●●●"
                android:textColor="#FF9800"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Healthy panels:"
                    android:textColor="#C3C3C3"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/faultHealthyCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="625"
                    android:textColor="#4CAF50"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Fault Type Breakdown -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2B3D"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FAULT TYPES"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/faultTypesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <!-- Fault types will be added dynamically -->
            </LinearLayout>
        </LinearLayout>

        <!-- Temperature Distribution -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2B3D"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEMPERATURE DISTRIBUTION"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/tempDistributionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <!-- Temperature ranges will be added dynamically -->
            </LinearLayout>
        </LinearLayout>

        <!-- Report Generation Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GENERATE REPORTS"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/buttonGenerateSiteReport"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="GENERATE SITE REPORT"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/buttonGenerateFaultReport"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="GENERATE FAULT REPORT"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/buttonGenerateMaintenanceReport"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="GENERATE MAINTENANCE REPORT"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="#FFFFFF" />
        </LinearLayout>

        <!-- Export Options -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPORT OPTIONS"
                android:textColor="#00D9FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <Button
                    android:id="@+id/buttonExportPDF"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Export PDF"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:background="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/buttonExportCSV"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Export CSV"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:background="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    android:layout_gravity="center_vertical" />

                <Button
                    android:id="@+id/buttonSendToCloud"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Send to Cloud"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:background="#FFFFFF"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
